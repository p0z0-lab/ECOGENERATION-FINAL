<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EcoLoja — Produtos de Energia Solar Portátil | EcoGeneration</title>
  <meta name="description" content="Encontre lâmpadas, ventiladores, painéis e kits solares portáteis. Soluções acessíveis para sua autonomia energética.">
  <meta name="robots" content="index, follow">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/ecoloja.css">
  <link rel="apple-touch-icon" href="/imagens/favicon2.png">
  <link rel="icon" href="/imagens/favicon2.png" type="image/png">
  <!-- OG -->
  <meta property="og:locale" content="pt_BR">
  <meta property="og:type" content="website">
  <meta property="og:title" content="EcoLoja — Produtos de Energia Solar Portátil">
  <meta property="og:description" content="Lâmpadas, ventiladores, painéis e kits solares portáteis. Soluções para sua autonomia energética.">
  <meta property="og:url" content="https://ecogeneration-final-4hh3.onrender.com/ecoloja">
  <meta property="og:site_name" content="EcoGeneration">
  <meta property="og:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/og-cover-v2.png">
  <meta property="og:image:secure_url" content="https://ecogeneration-final-4hh3.onrender.com/imagens/og-cover-v2.png">
  <meta property="og:image:type" content="image/png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="EcoLoja — Produtos Solares Portáteis">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="EcoLoja — Produtos de Energia Solar Portátil">
  <meta name="twitter:description" content="Lâmpadas, ventiladores, painéis e kits solares portáteis.">
  <meta name="twitter:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/og-cover-v2.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#2e7d32">
</head>
<body>
  <!-- WCAG 2.4.1 — Skip link para pular navegação direto ao conteúdo -->
  <a href="#conteudo-principal" class="skip-link">Ir para o conteúdo principal</a>

  <%- include("../partials/header") %>

  <main class="ecoloja-container" id="conteudo-principal">

    <header class="ecoloja-header">
      <h1>Produtos em Destaque</h1>
      <p>Conheça nossas soluções mais populares</p>
    </header>

    <section class="produtos-grid" aria-label="Lista de produtos disponíveis">
      <% if (produtos && produtos.length > 0) { %>
        <% produtos.forEach(function(produto) { %>
          <article class="produto-card">
            <figure class="produto-figura">
              <img
                src="/imagens/<%= produto.imagem_produto %>"
                alt="<%= produto.nome_produto %> — produto de energia solar portátil"
                class="produto-img"
                loading="lazy"
              >
            </figure>
            <section class="produto-info">
              <h2 class="produto-nome"><%= produto.nome_produto %></h2>
              <p class="produto-desc"><%= produto.descricao_produto %></p>
              <footer class="produto-rodape">
                <strong class="produto-preco" aria-label="Preço: R$ <%= produto.preco_produto %>">
                  R$ <%= produto.preco_produto %>
                </strong>
                <a
                  href="/produto/<%= produto.id_produto %>"
                  class="btn-comprar"
                  aria-label="Ver detalhes de <%= produto.nome_produto %>"
                >Ver produto</a>
              </footer>
            </section>
          </article>
        <% }) %>
      <% } else { %>
        <p class="sem-produtos">Nenhum produto encontrado.</p>
      <% } %>
    </section>

    <nav class="ecoloja-paginacao" aria-label="Paginação de produtos">
      <a href="/ecoloja?page=1" class="pagina-link <%= currentPage === 1 ? 'ativo' : '' %>" aria-label="Página 1" aria-current="<%= currentPage === 1 ? 'page' : 'false' %>">1</a>
      <a href="/ecoloja?page=2" class="pagina-link <%= currentPage === 2 ? 'ativo' : '' %>" aria-label="Página 2" aria-current="<%= currentPage === 2 ? 'page' : 'false' %>">2</a>
      <a href="/ecoloja?page=3" class="pagina-link <%= currentPage === 3 ? 'ativo' : '' %>" aria-label="Página 3" aria-current="<%= currentPage === 3 ? 'page' : 'false' %>">3</a>
    </nav>

  </main>

  <%- include("../partials/footer") %>
</body>
</html>
